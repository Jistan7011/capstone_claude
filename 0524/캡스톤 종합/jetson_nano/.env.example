CAM_INDEX=0
# CAM_BACKEND: auto(기본) | v4l2 | gstreamer  ← Jetson에서 영상 안 나올 때 gstreamer 시도
CAM_BACKEND=auto
# GST_PIPELINE: 커스텀 GStreamer 파이프라인 (비워두면 CAM_BACKEND에 따라 자동 생성)
# 예) GST_PIPELINE=v4l2src device=/dev/video0 ! videoconvert ! video/x-raw,format=BGR ! appsink max-buffers=1 drop=true
GST_PIPELINE=
CAP_W=640
CAP_H=480
CAP_FPS=20
STREAM_W=480
STREAM_H=360
STREAM_FPS=8
JPEG_QUALITY=55
ROI_START_RATIO=0.65
CENTER_DEADBAND=40
LOST_LINE_STOP_FRAMES=3
SERIAL_ENABLED=1
SERIAL_PORT=/dev/ttyUSB0
SERIAL_BAUD=115200
AUTO_ON_START=1
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
